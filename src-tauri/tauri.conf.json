{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FlyCat",
  "version": "0.1.0",
  "identifier": "com.feishu-docs-sync",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "飞猫助手",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true,
        "visible": true,
        "focus": true,
        "devtools": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
